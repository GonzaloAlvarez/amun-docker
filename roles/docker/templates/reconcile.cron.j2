{{ ansible_managed | comment }}
# Resilience cron for the {{ item.name }} stack — regenerated by `amun docker`.
# Do not edit by hand. Read by the system cron daemon from /etc/cron.d.
RESILIENCE_TEXTFILE_DIR={{ resiliency_textfile_dir }}
{% if item.reconcile.enabled | default(false) | bool %}
{{ item.reconcile.schedule | default('*/5 * * * *') }} root {{ resiliency_helper_path }} {{ item.project }} {{ item.working_dir }}
{% endif %}
{% for c in item.cron | default([]) %}
{{ c.schedule }} root {{ item.dir }}/{{ c.script }}
{% endfor %}
